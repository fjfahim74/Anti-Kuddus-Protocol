rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isCaptain() {
      return isSignedIn() && myProfile().role == 'captain';
    }

    // --- users/{uid} ---
    // Anyone signed in can read profiles (needed to show names on SOS alerts, etc).
    // A user can only create/update their OWN profile document.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // --- classes/{classId} ---
    // Shared class config (school name, class, section, roster size).
    // Any signed-in member of the class can read/update it (e.g. during setup).
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- sos_alerts/{alertId} ---
    // Any signed-in student can create an alert (only for themselves).
    // Anyone signed in can read (so the alert list renders for everyone).
    // Only captains can resolve/dismiss (update/delete) alerts.
    match /sos_alerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.triggeredBy == myProfile().rollNumber;
      allow update: if isCaptain();
      allow delete: if isCaptain();
    }

    // --- Everything else (complaints, corruption_reports, etc.) ---
    // Not yet migrated off localStorage — see SETUP_GUIDE.md.
    // Default-deny until you add explicit rules for a collection.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
