rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isCaptain() {
      return isSignedIn() && myProfile().role == 'captain';
    }

    // --- users/{uid} ---
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // --- classes/{classId} ---
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- sos_alerts/{alertId} ---
    match /sos_alerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.triggeredBy == myProfile().rollNumber;
      allow update: if isCaptain();
      allow delete: if isCaptain();
    }

    // --- Everything else — default-deny until migrated ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}